{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/app",
      "destination": "/lesson-review-ui/upload.html"
    },
    {
      "source": "/app/(.*)",
      "destination": "/lesson-review-ui/$1"
    },
    {
      "source": "/",
      "destination": "/lesson-review-ui/upload.html"
    }
  ]
}
