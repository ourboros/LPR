{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    },
    "api/[...route].js": {
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api(?<path>/.*)?",
      "dest": "/api/[...route].js"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/app/upload.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/app",
      "destination": "/lesson-review-ui/upload.html"
    },
    {
      "source": "/app/(.*)",
      "destination": "/lesson-review-ui/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/lesson-review-ui/assets/$1"
    }
  ]
}
