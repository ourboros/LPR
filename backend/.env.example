PORT=5000

# MongoDB connection
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_DB_NAME=lpr

# Optional fallback for Atlas SRV DNS issues.
# Paste Atlas direct connection string here if mongodb+srv cannot be resolved in your network.
MONGODB_URI_DIRECT=

# Search engine mode
SEARCH_ENGINE=simple

# Gemini settings
# Keep real key value only in backend/.env
GEMINI_API_KEY=your_api_key_here
EMBEDDING_MODEL=models/embedding-001
LLM_MODEL=gemini-2.5-flash-lite
